# ===========================================================================
# Hermes Agent — Environment Variables
# Copy to .env and fill in your values.
# On Railway: paste directly into the Variables tab.
# ===========================================================================

# ---------------------------------------------------------------------------
# LLM Provider (at least one required)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# GOOGLE_API_KEY=
# MISTRAL_API_KEY=
# GROQ_API_KEY=

# ---------------------------------------------------------------------------
# Chat platform integrations
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# Gateway API server
# API_SERVER_KEY must be >= 8 chars. Generate: openssl rand -hex 32
# ---------------------------------------------------------------------------
API_SERVER_ENABLED=false
API_SERVER_HOST=0.0.0.0
API_SERVER_KEY=
API_SERVER_CORS_ORIGINS=*

# ---------------------------------------------------------------------------
# Dashboard
# ---------------------------------------------------------------------------
HERMES_DASHBOARD=1
HERMES_DASHBOARD_HOST=0.0.0.0
HERMES_DASHBOARD_PORT=9119
# HERMES_DASHBOARD_TUI=1

# ---------------------------------------------------------------------------
# Railway routing — must match the port Railway routes to
# ---------------------------------------------------------------------------
PORT=8642

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# HERMES_ALLOW_ROOT_GATEWAY=1
# HERMES_UID=1000
# HERMES_GID=1000

# ---------------------------------------------------------------------------
# Optional tooling
# ---------------------------------------------------------------------------
# BROWSERLESS_API_KEY=
# TAVILY_API_KEY=
# SERPER_API_KEY=
# E2B_API_KEY=
